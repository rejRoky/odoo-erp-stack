# ── PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_DB=odoo
POSTGRES_USER=odoo
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=CHANGE_ME_replication_password

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── Odoo ──────────────────────────────────────────────────────────
ODOO_MASTER_PASSWORD=CHANGE_ME_odoo_master_password
ODOO_ADMIN_EMAIL=admin@yourdomain.com

# ── Grafana ───────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_grafana_password

# ── Domain (production) ───────────────────────────────────────────
DOMAIN=yourdomain.com
CERTBOT_EMAIL=admin@yourdomain.com

# ── Backup storage (S3-compatible: AWS S3, Backblaze B2, MinIO) ───
S3_BUCKET=your-erp-backup-bucket
S3_ENDPOINT=https://s3.amazonaws.com
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1
